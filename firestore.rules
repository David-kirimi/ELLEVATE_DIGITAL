rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "muriiradavie@gmail.com" ||
         request.auth.token.email == "superadmin@eliax.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() && (isOwner(userId) || isAdmin())) && (
        (request.resource.data.role == 'fan' && request.resource.data.points == 10) ||
        isAdmin()
      );
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Site Settings
    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contestants
    match /contestants/{contestantId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Contestant Posts
    match /contestantPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.contestantUid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.contestantUid == request.auth.uid;
    }

    // Application Questions
    match /applicationQuestions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Votes
    match /votes/{voteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.fanUid == request.auth.uid &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.points >= request.resource.data.pointsSpent;
    }

    // Courses (Public Metadata)
    match /courses/{courseId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerifiedCreator == true) ||
        isAdmin()
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.creatorUid == request.auth.uid || isAdmin()
      );
    }

    // Course Contents (Private)
    match /courseContents/{courseId} {
      function hasPurchased() {
        return exists(/databases/$(database)/documents/purchases/$(request.auth.uid + "_" + courseId));
      }
      function hasSubscription() {
        return exists(/databases/$(database)/documents/subscriptions/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/subscriptions/$(request.auth.uid)).data.status == 'active' && 
          get(/databases/$(database)/documents/subscriptions/$(request.auth.uid)).data.expiresAt > request.time;
      }
      function isCreator() {
        return exists(/databases/$(database)/documents/courses/$(courseId)) &&
          get(/databases/$(database)/documents/courses/$(courseId)).data.creatorUid == request.auth.uid;
      }

      allow read: if isAuthenticated() && (isCreator() || hasPurchased() || hasSubscription() || isAdmin());
      allow create, update, delete: if isAuthenticated() && 
        exists(/databases/$(database)/documents/courses/$(courseId)) &&
        get(/databases/$(database)/documents/courses/$(courseId)).data.creatorUid == request.auth.uid;
    }

    // Purchases
    match /purchases/{purchaseId} {
      allow read: if isAuthenticated() && (
        resource.data.userUid == request.auth.uid || 
        resource.data.creatorUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userUid == request.auth.uid &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.points >= request.resource.data.amountPaid;
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
      allow update: if isAdmin();
    }

    // Subscriptions
    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    // Contestant Applications
    match /contestantApplications/{applicationId} {
      allow read: if isAuthenticated() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
